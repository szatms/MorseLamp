<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/btnPreset"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Preset messages"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnTextToMorse"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_margin="12dp"/>

    <Button
        android:id="@+id/btnTextToMorse"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Text to Morse"
        app:layout_constraintTop_toBottomOf="@id/btnPreset"
        app:layout_constraintBottom_toTopOf="@id/btnQuick"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp"/>

    <Button
        android:id="@+id/btnQuick"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Quick messages"
        app:layout_constraintTop_toBottomOf="@id/btnTextToMorse"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>